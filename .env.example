# -----------------------------------------------------------------------------
# Core app runtime: required for local development and production
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Store/runtime defaults
# -----------------------------------------------------------------------------
MYRIVO_SINGLE_STORE_SLUG=at-home-apothecary

# -----------------------------------------------------------------------------
# Onboarding AI
# -----------------------------------------------------------------------------
# Options: deterministic | openai
MYRIVO_ONBOARDING_AI_PROVIDER=deterministic
# Defaults to gpt-5-mini when OpenAI is enabled and this is blank.
MYRIVO_ONBOARDING_AI_MODEL=
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Email delivery
# -----------------------------------------------------------------------------
# Options: resend
MYRIVO_EMAIL_PROVIDER=resend
RESEND_API_KEY=
MYRIVO_EMAIL_FROM=
MYRIVO_EMAIL_PLATFORM_FROM=
MYRIVO_EMAIL_REPLY_TO=
MYRIVO_EMAIL_BRANDED_LOCAL_PART=orders
# Options: disabled | allowlist | all
MYRIVO_BRANDED_EMAIL_POLICY=disabled
MYRIVO_BRANDED_EMAIL_STORE_IDS=
MYRIVO_ORDER_ALERT_EMAILS=

# -----------------------------------------------------------------------------
# Stripe / payments
# -----------------------------------------------------------------------------
# Local-only convenience flag. Leave false in production.
STRIPE_STUB_MODE=false
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Shipping
# -----------------------------------------------------------------------------
SHIPPING_ALLOW_QUERY_TOKEN=false
SHIPPING_WEBHOOK_SIGNING_SECRET=
SHIPPING_WEBHOOK_REQUIRE_SIGNATURE=true
SHIPPING_WEBHOOK_SIGNATURE_TOLERANCE_SECONDS=300

# -----------------------------------------------------------------------------
# Reviews and storefront review schema
# -----------------------------------------------------------------------------
REVIEWS_ROLLOUT_STORE_SLUGS=
REVIEWS_MAX_SUBMISSIONS_PER_IP_PER_HOUR=8
REVIEWS_MAX_SUBMISSIONS_PER_EMAIL_PER_DAY=5
REVIEWS_BLOCKED_TERMS=
REVIEWS_MEDIA_MAX_IMAGES_PER_REVIEW=8
REVIEWS_MEDIA_MAX_FILE_SIZE_BYTES=8388608
REVIEWS_MEDIA_MAX_WIDTH=6000
REVIEWS_MEDIA_MAX_HEIGHT=6000
STOREFRONT_REVIEW_SCHEMA_MIN_COUNT=1
STOREFRONT_REVIEW_SCHEMA_MAX_RECENT=3

# -----------------------------------------------------------------------------
# Notifications / scheduled jobs
# -----------------------------------------------------------------------------
NOTIFICATIONS_CRON_SECRET=

# -----------------------------------------------------------------------------
# Vercel domain automation (only if using Vercel domain APIs from the app)
# -----------------------------------------------------------------------------
VERCEL_API_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=

# -----------------------------------------------------------------------------
# Local / CI / E2E only
# -----------------------------------------------------------------------------
E2E_OWNER_EMAIL=
E2E_OWNER_PASSWORD=
E2E_ALLOW_OWNER_PASSWORD_RESET=false
E2E_BASE_URL=
E2E_PORT=3000
E2E_MANAGED_SERVER=false
